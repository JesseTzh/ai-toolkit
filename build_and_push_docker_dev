#!/usr/bin/env bash

VERSION=dev

echo "Docker builds from the current working tree."
echo "Building version: $VERSION"
# wait 2 seconds
sleep 2

# Build the image. Docker invalidates the source layer when working-tree files change.
docker build -t aitoolkit:$VERSION -f docker/Dockerfile .

# Tag with version and latest
docker tag aitoolkit:$VERSION ostris/aitoolkit:$VERSION

# Push both tags
echo "Pushing images to Docker Hub..."
docker push ostris/aitoolkit:$VERSION

echo "Successfully built and pushed ostris/aitoolkit:$VERSION"
